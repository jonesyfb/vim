@@ -419,6 +419,17 @@ def ProcessLspServerError(method: string, responseError: dict<any>)
     return
   endif
 
+  # dotfiles patch: a server-initiated retrigger is a normal protocol
+  # signal to resend the request, not a real error - silently return here
+  # too. AsyncRpcCb (unlike the sync Rpc()) has no handleError suppression,
+  # so this is needed for async callers (e.g. PullDiagnostics) to avoid a
+  # spurious error message on every routine retrigger.
+  if responseError.code == LSP_ERROR_SERVER_CANCELLED
+      && responseError->get('data', {})->type() == v:t_dict
+      && responseError.data->get('retriggerRequest', false)
+    return
+  endif
+
   var emsg: string = responseError.message
   emsg ..= $', error = {LspGetErrorMessage(responseError.code)}'
   if responseError->has_key('data')
